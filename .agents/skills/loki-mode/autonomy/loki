    # Show raw body preview if nothing else was extracted
    if [[ -z "$problem" && -z "$acceptance" && -z "$technical" && -n "$raw_body" ]]; then
        echo -e "${BOLD}Issue Body${NC}"
        echo "─────────────────────────────────────────────────────────────────────────"
        echo "$raw_body" | head -20
        echo ""
    fi

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
