            echo -e "${BOLD}GitHub Integration Status${NC}"
            echo ""

            # gh CLI
            if command -v gh &>/dev/null; then
                echo -e "  gh CLI:       ${GREEN}installed $(gh --version 2>/dev/null | head -1 | sed 's/gh version /v/')${NC}"
