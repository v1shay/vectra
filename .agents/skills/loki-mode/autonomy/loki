    _ci_scan 'console\.(log|debug)\(' "LOW" "anti-pattern" \
        "console.log/debug statement found" \
        "Remove debug logging or use a proper logger"

    _ci_scan 'except\s*:' "MEDIUM" "anti-pattern" \
        "Bare except clause" \
        "Catch specific exceptions"

