                exit 1
            fi

            if ! command -v gh &>/dev/null; then
                echo -e "${RED}Error: gh CLI not found. Install with: brew install gh${NC}"
                exit 1
            fi

            echo -e "${GREEN}Exporting local tasks to GitHub issues...${NC}"
