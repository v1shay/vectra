            echo -e "  LOKI_GITHUB_IMPORT:  ${LOKI_GITHUB_IMPORT:-false}"
            echo -e "  LOKI_GITHUB_SYNC:    ${LOKI_GITHUB_SYNC:-false}"
            echo -e "  LOKI_GITHUB_PR:      ${LOKI_GITHUB_PR:-false}"
