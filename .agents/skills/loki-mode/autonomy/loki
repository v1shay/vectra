    m = json.load(f)
m['status'] = 'paused'
m['updated_at'] = datetime.now().isoformat()
with open(manifest_path, 'w') as f:
    json.dump(m, f, indent=2)
" "${migration_dir}/manifest.json" || {
            echo -e "${RED}Error: Failed to update migration state${NC}"
            return 1
        }
        return 0
    fi

    # Mark migration complete
    python3 -c "
import json, sys
