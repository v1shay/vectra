    # Acceptance criteria
    if [[ -n "$acceptance" && "$acceptance" != "null" ]]; then
        echo -e "${BOLD}Acceptance Criteria${NC}"
        echo "─────────────────────────────────────────────────────────────────────────"
        echo "$acceptance" | head -15
        echo ""
    fi

    # Technical requirements
    if [[ -n "$technical" && "$technical" != "null" ]]; then
        echo -e "${BOLD}Technical Requirements${NC}"
        echo "─────────────────────────────────────────────────────────────────────────"
