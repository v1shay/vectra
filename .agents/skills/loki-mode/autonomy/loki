        fi
        echo ""
    fi

    # Plan-only: generate plan file and stop
    if [ "$plan_only" = "true" ]; then
        echo -e "${BOLD}Migration plan generated.${NC}"
        echo -e "View with: loki migrate --show-plan"

        python3 -c "
import json, sys
